@model Portfolio.Models.Resume
@{
    ViewData["Title"] = "Home";
    var contact = Model?.Contact ?? new Portfolio.Models.ContactInfo();
    var imageUrl = !string.IsNullOrEmpty(contact.ProfileImageUrl) ? contact.ProfileImageUrl : "/images/profile.jpeg";
    var initials = contact.Name != null && contact.Name.Length >= 2
        ? (contact.Name.Split(' ').Length >= 2
            ? string.Concat(contact.Name.Split(' ')[0][0], contact.Name.Split(' ')[1][0]).ToUpperInvariant()
            : contact.Name.Length >= 2 ? contact.Name.Substring(0, 2).ToUpperInvariant() : "AV")
        : "AV";
}
<div class="container">
    <div class="hero text-center">
        <div class="profile-photo-wrap rounded-circle mx-auto d-flex align-items-center justify-content-center bg-primary text-white fw-bold hero-photo" style="font-size: 3rem;">
            <img src="@imageUrl" alt="@contact.Name" class="rounded-circle w-100 h-100" style="object-fit: cover;" onerror="this.style.display='none'; var s=this.nextElementSibling; s.style.display='flex'; s.classList.remove('d-none');" />
            <span class="profile-initials d-none align-items-center justify-content-center rounded-circle w-100 h-100">@initials</span>
        </div>
        <h1 class="hero-name">@contact.Name</h1>
        <p class="hero-title">@contact.Title</p>
        <p class="hero-location">@contact.Location</p>
        <div class="hero-links mb-3 d-flex flex-wrap justify-content-center align-items-center gap-2">
            @if (!string.IsNullOrEmpty(contact.Email))
            {
                <a href="mailto:@contact.Email" class="d-flex align-items-center gap-1"><i class="bi bi-envelope" style="font-size: 1.1rem;"></i> @contact.Email</a>
            }
            @if (!string.IsNullOrEmpty(contact.LinkedIn))
            {
                <a href="@contact.LinkedIn" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="bi bi-linkedin" style="font-size: 1.5rem;"></i></a>
            }
            @if (!string.IsNullOrEmpty(contact.GitHub))
            {
                <a href="@contact.GitHub" target="_blank" rel="noopener" aria-label="GitHub"><i class="bi bi-github" style="font-size: 1.5rem;"></i></a>
            }
        </div>
        <p class="text-muted mb-4 mx-auto" style="max-width: 36rem; line-height: 1.7;">
            Software Developer with 4+ years of experience in .NET, ASP.NET Core, Blazor, and full-stack development. Experienced in building APIs, microservices, and modern web applications.
        </p>
        <div class="hero-buttons d-flex flex-wrap justify-content-center gap-2">
            <a asp-controller="Resume" asp-action="Experience" class="btn btn-primary btn-primary-custom">Experience</a>
            <a asp-controller="Resume" asp-action="Skills" class="btn btn-outline-custom">Skills</a>
            <a asp-controller="Resume" asp-action="Education" class="btn btn-outline-custom">Education</a>
            <a asp-controller="Resume" asp-action="Achievements" class="btn btn-outline-custom">Achievements</a>
            <a asp-controller="Resume" asp-action="Contact" class="btn btn-outline-custom">Contact</a>
        </div>
    </div>
</div>
