@model Portfolio.Models.Resume
@{
    ViewData["Title"] = "Education";
    var education = Model?.Education ?? new List<Portfolio.Models.EducationItem>();
}
<div class="container">
    <h2 class="section-title">Education</h2>
    @foreach (var item in education)
    {
        <div class="card card-modern mb-4">
            <div class="card-body">
                <h5 class="card-title-modern">@item.Degree</h5>
                <h6 class="card-subtitle-modern">@item.Institution @(item.Board != null ? " – " + item.Board : "")</h6>
                <p class="text-muted mb-0">@item.Period · @item.Grade</p>
            </div>
        </div>
    }
</div>
