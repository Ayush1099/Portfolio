@model Portfolio.Models.Resume
@{
    ViewData["Title"] = "Experience";
    var experience = Model?.Experience ?? new List<Portfolio.Models.ExperienceItem>();
}
<div class="container">
    <h2 class="section-title">Experience</h2>
    @foreach (var item in experience)
    {
        <div class="card card-modern mb-4">
            <div class="card-body">
                <h5 class="card-title-modern">@item.Role at @item.Company</h5>
                <h6 class="card-subtitle-modern">@item.Location · @item.Period</h6>
                <ul class="list-bullets">
                    @foreach (var bullet in item.BulletPoints)
                    {
                        <li>@bullet</li>
                    }
                </ul>
            </div>
        </div>
    }
</div>
