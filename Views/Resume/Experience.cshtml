@model Portfolio.Models.Resume
@{
    ViewData["Title"] = "Experience";
    var experience = Model?.Experience ?? new List<Portfolio.Models.ExperienceItem>();
}
<h2 class="mb-4">Experience</h2>
@foreach (var item in experience)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">@item.Role at @item.Company</h5>
            <h6 class="card-subtitle mb-2 text-muted">@item.Location · @item.Period</h6>
            <ul class="card-text mb-0">
                @foreach (var bullet in item.BulletPoints)
                {
                    <li>@bullet</li>
                }
            </ul>
        </div>
    </div>
}
